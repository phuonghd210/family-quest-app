<!-- ============================================================
     SCRIPT
============================================================ -->
<script>
// ============================================================
// CONFIG — ĐỔI URL NÀY
// ============================================================
const API_URL = 'https://script.google.com/macros/s/AKfycbxJwpMxT1gMADbf8CGcCZDkRsX68uwHh4_1lquJ8ryg3icDns4LEVByTVFyMtJEXsqo/exec';

// ============================================================
// STATE
// ============================================================
let S = {
  token:       localStorage.getItem('fq_token') || null,
  user:        JSON.parse(localStorage.getItem('fq_user') || 'null'),
  children:    [],
  tasks:       [],
  rewards:     [],
  transactions:[],
  dailyStatus: [],
  redemptions: [],
  today:       '',
  week_start:  '',
  activeTab:   'today',
  taskFilter:  'all'
};

// ============================================================
// API HELPER
// ============================================================
async function api(action, payload = {}) {
  const res = await fetch(API_URL, {
    method: 'POST',
    body: JSON.stringify({ action, token: S.token, payload })
  });
  if (!res.ok) throw new Error('HTTP ' + res.status);
  return res.json();
}

// ============================================================
// FETCH ALL DATA
// ============================================================
async function fetchData(silent = false) {
  if (!silent) showLoad(true);
  try {
    const r = await api('getInitialData');
    if (r.success) {
      S.children     = (r.children     || []).filter(c => c.status === 'active' || !c.status);
      S.tasks        = (r.tasks        || []).filter(t => t.status === 'active');
      S.rewards      = (r.rewards      || []).filter(rw => rw.status === 'active');
      S.transactions = r.transactions  || [];
      S.dailyStatus  = r.dailyStatus   || [];
      S.redemptions  = r.redemptions   || [];
      S.today        = r.today         || '';
      S.week_start   = r.week_start    || '';
      renderTab(S.activeTab);
    } else {
      if (!silent) toast(r.message || 'Không tải được dữ liệu', 'error');
    }
  } catch(e) {
    if (!silent) toast('⚠️ Không kết nối được server', 'error');
  }
  if (!silent) showLoad(false);
}

async function doRefresh() {
  const btn = document.getElementById('btn-refresh');
  btn.classList.add('spinning');
  await fetchData(true);
  btn.classList.remove('spinning');
  toast('Đã làm mới dữ liệu ✅', 'success');
}

// ============================================================
// SCORE HELPERS (dùng giá trị pre-computed từ server)
// ============================================================
function childScore(childId) {
  const c = S.children.find(x => String(x.child_id) === String(childId));
  if (!c) return { today_score:0, week_score:0, total_score:0, earned_score:0, daily_target:50 };
  return {
    today_score:  Number(c.today_score  || 0),
    week_score:   Number(c.week_score   || 0),
    total_score:  Number(c.total_score  || 0),
    earned_score: Number(c.earned_score || 0),
    daily_target: Number(c.daily_target || 50)
  };
}

// ============================================================
// TASK HELPERS
// ============================================================
function isTaskDone(childId, taskId) {
  return S.dailyStatus.some(ds =>
    String(ds.child_id) === String(childId) &&
    String(ds.task_id)  === String(taskId)  &&
    (ds.status === 'done' || ds.status === 'completed')
  );
}

function taskAppliesTo(task, child) {
  const at = String(task.assigned_to || 'both').toLowerCase();
  if (at === 'both') return true;
  return at === String(child.child_id).toLowerCase() ||
         at === String(child.child_key || '').toLowerCase();
}

// ============================================================
// LOGIN / LOGOUT
// ============================================================
async function handleLogin(e) {
  e.preventDefault();
  const username = document.getElementById('inp-user').value.trim();
  const password = document.getElementById('inp-pass').value.trim();
  const errEl    = document.getElementById('login-error');
  errEl.style.display = 'none';

  if (!username || !password) { toast('Nhập username và password', 'warn'); return; }

  showLoad(true);
  try {
    const r = await api('login', { username, password });
    if (r.success) {
      S.token = r.token;
      S.user  = {
        user_id:      r.user_id,
        username:     r.username,
        display_name: r.display_name,
        role:         r.role,
        child_id:     r.child_id || null
      };
      localStorage.setItem('fq_token', r.token);
      localStorage.setItem('fq_user',  JSON.stringify(S.user));
      showApp();
      await fetchData(true);
      showLoad(false);
    } else {
      errEl.style.display = 'block';
      showLoad(false);
    }
  } catch(err) {
    toast('⚠️ Không kết nối được server. Kiểm tra API_URL và thử lại.', 'error');
    showLoad(false);
  }
}

function handleLogout() {
  S.token = null; S.user = null;
  localStorage.removeItem('fq_token');
  localStorage.removeItem('fq_user');
  showLogin();
}

function togglePw() {
  const inp = document.getElementById('inp-pass');
  inp.type  = inp.type === 'password' ? 'text' : 'password';
}

// ============================================================
// SESSION RESTORE
// ============================================================
async function init() {
  buildLoginChars();
  if (S.token && S.user) {
    try {
      const r = await api('validateSession');
      if (r.success) {
        S.user = { user_id: r.user_id, username: r.username, display_name: r.display_name, role: r.role, child_id: r.child_id };
        localStorage.setItem('fq_user', JSON.stringify(S.user));
        showApp();
        await fetchData(true);
        return;
      }
    } catch(e) {}
    S.token = null; S.user = null;
    localStorage.removeItem('fq_token');
    localStorage.removeItem('fq_user');
  }
  showLogin();
}

function buildLoginChars() {
  // Static decorative buttons for login screen
  const row = document.getElementById('chars-row');
  const chars = [
    { icon: '⚔️', name: 'Bố / Mẹ',     role: 'admin / scorer' },
    { icon: '🌸', name: 'Các bé',        role: 'viewer' }
  ];
  row.innerHTML = chars.map(c => `
    <div class="char-btn">
      <span class="char-icon">${c.icon}</span>
      <span class="char-name">${c.name}</span>
      <span class="char-role">${c.role}</span>
    </div>
  `).join('');
}

// ============================================================
// UI HELPERS
// ============================================================
function showLogin() {
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('app').classList.remove('visible');
}

function showApp() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').classList.add('visible');
  document.getElementById('user-badge').textContent =
    (S.user?.display_name || '?') + ' · ' + (S.user?.role || '');
  // Show settings tab only for admin/scorer
  const settingsBtn = document.getElementById('tab-btn-settings');
  if (S.user?.role === 'admin' || S.user?.role === 'scorer') {
    settingsBtn.style.display = '';
  }
  switchTab('today');
}

function showLoad(v) {
  document.getElementById('loading').style.display = v ? 'flex' : 'none';
}

let toastTimer = null;
function toast(msg, type = 'info') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show ' + type;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3200);
}

function switchTab(tab) {
  S.activeTab = tab;
  document.querySelectorAll('.tab-btn').forEach(b =>
    b.classList.toggle('active', b.dataset.tab === tab)
  );
  document.querySelectorAll('.tab-content').forEach(t =>
    t.style.display = (t.id === 'tab-' + tab) ? '' : 'none'
  );
  renderTab(tab);
}

function renderTab(tab) {
  switch (tab) {
    case 'today':    renderToday();    break;
    case 'tasks':    renderTasks();    break;
    case 'points':   renderPoints();   break;
    case 'rewards':  renderRewards();  break;
    case 'rankings': renderRankings(); break;
    case 'history':  renderHistory();  break;
    case 'settings': renderSettings(); break;
  }
}

// confirm modal
let modalCb = null;
function confirm(title, body, cb) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').textContent  = body;
  modalCb = cb;
  document.getElementById('modal-overlay').classList.add('show');
  document.getElementById('modal-ok').onclick = () => { closeModal(); if (modalCb) modalCb(); };
}
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}

function fmtDate(d) {
  if (!d) return '';
  const s = String(d).substring(0, 10);
  const parts = s.split('-');
  return `${parts[2]}/${parts[1]}`;
}

function fmtDatetime(d) {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt)) return String(d).substring(0,16);
  return `${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')} ${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;
}

// ============================================================
// RENDER: TODAY
// ============================================================
function renderToday() {
  const el = document.getElementById('tab-today');
  if (!S.children.length) {
    el.innerHTML = '<div class="empty-state"><div class="es-icon">🌞</div><p>Đang tải dữ liệu...</p></div>';
    return;
  }

  const scored = S.children.map(c => ({ ...c, ...childScore(c.child_id) }));
  const todayLeader = scored.reduce((a,b) => a.today_score >= b.today_score ? a : b);
  const weekLeader  = scored.reduce((a,b) => a.week_score  >= b.week_score  ? a : b);

  let html = `
    <div class="sec-title">🌞 Hôm Nay · ${fmtDate(S.today)}</div>

    <div class="leaders-banner">
      <div class="leader-item">
        <span class="leader-label">🌞 Dẫn đầu hôm nay</span>
        <span class="leader-name">${todayLeader.avatar_icon || '⭐'} ${todayLeader.child_name}</span>
      </div>
      <div class="leader-item">
        <span class="leader-label">📅 Dẫn đầu tuần</span>
        <span class="leader-name">${weekLeader.avatar_icon || '⭐'} ${weekLeader.child_name}</span>
      </div>
    </div>

    <div class="child-cards">
  `;

  scored.forEach(c => {
    const pct = Math.min(100, c.daily_target > 0 ? Math.round(c.today_score / c.daily_target * 100) : 0);
    html += `
      <div class="child-card">
        <div class="child-card-head">
          <span class="child-card-avatar">${c.avatar_icon || '⭐'}</span>
          <div class="child-card-info">
            <h3>${c.child_name}</h3>
            <span>${c.avatar_name || ''}</span>
          </div>
        </div>
        <div class="score-row">
          <div class="score-box">
            <div class="sv">${c.today_score}</div>
            <div class="sl">🌞 Hôm nay</div>
          </div>
          <div class="score-box">
            <div class="sv">${c.week_score}</div>
            <div class="sl">📅 Tuần này</div>
          </div>
          <div class="score-box">
            <div class="sv" style="color:var(--blue)">${c.total_score} ⭐</div>
            <div class="sl">Ngôi sao</div>
          </div>
        </div>
        <div class="prog-wrap">
          <div class="prog-label">
            <span>Tiến độ hôm nay</span>
            <span>${c.today_score} / ${c.daily_target}</span>
          </div>
          <div class="prog-bar">
            <div class="prog-fill" style="width:${pct}%"></div>
          </div>
        </div>
      </div>
    `;
  });

  html += '</div>';
  el.innerHTML = html;
}

// ============================================================
// RENDER: TASKS
// ============================================================
function renderTasks() {
  const el = document.getElementById('tab-tasks');
  const canInteract = S.user?.role === 'admin' || S.user?.role === 'scorer';

  const cats = [
    { key: 'all',           label: '🔍 Tất cả' },
    { key: 'Tác phong hằng ngày', label: '🌅 Tác phong' },
    { key: 'Việc nhà',      label: '🏠 Việc nhà' },
    { key: 'Học tập',       label: '📚 Học tập' },
    { key: 'Điểm phát sinh',label: '⚡ Phát sinh' },
    { key: 'Thành tích',    label: '🏆 Thành tích' }
  ];

  const activeTasks = S.tasks.filter(t => {
    if (S.taskFilter === 'all') return true;
    return t.category === S.taskFilter;
  });

  // Group by category
  const groups = {};
  activeTasks.forEach(t => {
    const cat = t.category || 'Khác';
    if (!groups[cat]) groups[cat] = [];
    groups[cat].push(t);
  });

  let html = `
    <div class="sec-title">✅ Nhiệm Vụ Hôm Nay</div>
    <div class="cat-filter">
      ${cats.map(c => `
        <div class="cat-pill ${S.taskFilter === c.key ? 'active' : ''}"
             onclick="setTaskFilter('${c.key}')">${c.label}</div>
      `).join('')}
    </div>
  `;

  if (!activeTasks.length) {
    html += '<div class="empty-state"><div class="es-icon">✅</div><p>Không có nhiệm vụ nào</p></div>';
    el.innerHTML = html;
    return;
  }

  Object.entries(groups).forEach(([cat, tasks]) => {
    html += `<div class="cat-section"><div class="cat-section-title">${cat}</div>`;
    tasks.forEach(task => {
      const applicable = S.children.filter(c => taskAppliesTo(task, c));
      if (!applicable.length) return;

      html += `
        <div class="task-item">
          <div class="task-item-head">
            <span class="task-name-text">${task.task_name}</span>
            <span class="task-pts-badge">+${task.points} ⭐</span>
          </div>
          <div class="task-checks">
      `;
      applicable.forEach(child => {
        const done = isTaskDone(child.child_id, task.task_id);
        const ro   = !canInteract ? 'readonly' : '';
        html += `
          <label class="check-label ${done ? 'done' : ''} ${ro}"
                 id="lbl-${child.child_id}-${task.task_id}"
                 onclick="${canInteract ? `handleTaskToggle('${child.child_id}','${task.task_id}',${done})` : ''}">
            <div class="check-box">${done ? '✓' : ''}</div>
            <span class="check-child-name">${child.avatar_icon || ''} ${child.child_name}</span>
          </label>
        `;
      });
      html += `</div></div>`;
    });
    html += '</div>';
  });

  el.innerHTML = html;
}

function setTaskFilter(key) {
  S.taskFilter = key;
  renderTasks();
}

// ============================================================
// TASK TOGGLE (complete / undo)
// ============================================================
async function handleTaskToggle(childId, taskId, isDone) {
  if (S.user?.role !== 'admin' && S.user?.role !== 'scorer') return;

  const child = S.children.find(c => String(c.child_id) === String(childId));
  const task  = S.tasks.find(t => String(t.task_id) === String(taskId));
  if (!child || !task) return;

  const lbl = document.getElementById(`lbl-${childId}-${taskId}`);
  if (lbl) { lbl.style.opacity = '0.5'; lbl.style.pointerEvents = 'none'; }

  showLoad(true);
  try {
    if (!isDone) {
      // Complete task
      const r = await api('completeTask', { child_id: childId, task_id: taskId });
      if (r.success) {
        toast(`✅ ${child.child_name}: +${task.points} ⭐`, 'success');
        await fetchData(true);
      } else {
        toast(r.message, 'error');
        if (lbl) { lbl.style.opacity = ''; lbl.style.pointerEvents = ''; }
      }
    } else {
      // Undo task
      const r = await api('undoTask', { child_id: childId, task_id: taskId });
      if (r.success) {
        toast(`↩️ ${child.child_name}: -${task.points} ⭐`, 'warn');
        await fetchData(true);
      } else {
        toast(r.message, 'error');
        if (lbl) { lbl.style.opacity = ''; lbl.style.pointerEvents = ''; }
      }
    }
  } catch(e) {
    toast('Lỗi kết nối', 'error');
    if (lbl) { lbl.style.opacity = ''; lbl.style.pointerEvents = ''; }
  }
  showLoad(false);
}

// ============================================================
// RENDER: POINTS (bonus/penalty)
// ============================================================
function renderPoints() {
  const el       = document.getElementById('tab-points');
  const canAct   = S.user?.role === 'admin' || S.user?.role === 'scorer';
  const recentTx = S.transactions.slice(0, 20);

  let childOpts = S.children.map(c =>
    `<option value="${c.child_id}">${c.avatar_icon || ''} ${c.child_name}</option>`
  ).join('');

  let formHtml = '';
  if (canAct) {
    formHtml = `
      <div class="points-form">
        <div class="form-row">
          <label>👶 Chọn bé</label>
          <select id="bp-child" class="form-select">${childOpts}</select>
        </div>
        <div class="form-row">
          <label>Loại</label>
          <div class="type-toggle">
            <button type="button" id="btn-bonus"   class="type-btn active-bonus"   onclick="setBpType('bonus')">➕ Thưởng</button>
            <button type="button" id="btn-penalty" class="type-btn"                onclick="setBpType('penalty')">➖ Phạt</button>
          </div>
          <input type="hidden" id="bp-type" value="bonus" />
        </div>
        <div class="form-row">
          <label>📝 Lý do</label>
          <input id="bp-note" class="form-input" type="text" placeholder="Nhập lý do..." />
        </div>
        <div class="form-row">
          <label>🔢 Số điểm</label>
          <input id="bp-pts"  class="form-input" type="number" min="1" placeholder="VD: 10" />
        </div>
        <button class="btn-submit" onclick="submitBonusPenalty()">✅ Xác Nhận</button>
      </div>
    `;
  }

  let txHtml = recentTx.length ? recentTx.map(tx => {
    const pts = Number(tx.points || 0);
    return `
      <div class="tx-item">
        <div class="tx-left">
          <div class="tx-name">${tx.child_name || ''} · ${tx.type || ''}</div>
          <div class="tx-meta">${tx.note || tx.task_name || ''} · ${fmtDatetime(tx.created_at)}</div>
        </div>
        <div class="tx-pts ${pts >= 0 ? 'pos' : 'neg'}">${pts >= 0 ? '+' : ''}${pts}</div>
      </div>
    `;
  }).join('') : '<div class="empty-state"><div class="es-icon">📜</div><p>Chưa có giao dịch nào</p></div>';

  el.innerHTML = `
    <div class="sec-title">✨ Thưởng / Phạt Điểm</div>
    ${formHtml}
    <div class="recent-tx">
      <div class="sec-title" style="margin-top:20px">📜 Giao Dịch Gần Đây</div>
      ${txHtml}
    </div>
  `;
}

function setBpType(type) {
  document.getElementById('bp-type').value = type;
  const bBtn = document.getElementById('btn-bonus');
  const pBtn = document.getElementById('btn-penalty');
  bBtn.className = 'type-btn' + (type === 'bonus'   ? ' active-bonus'   : '');
  pBtn.className = 'type-btn' + (type === 'penalty' ? ' active-penalty' : '');
}

async function submitBonusPenalty() {
  const childId = document.getElementById('bp-child').value;
  const type    = document.getElementById('bp-type').value;
  const note    = document.getElementById('bp-note').value.trim();
  const pts     = Number(document.getElementById('bp-pts').value);

  if (!childId) { toast('Chọn bé', 'warn'); return; }
  if (!pts || pts <= 0) { toast('Nhập số điểm hợp lệ', 'warn'); return; }

  showLoad(true);
  try {
    const r = await api('addBonusPenalty', { child_id: childId, type, note, points: pts });
    if (r.success) {
      toast(r.message, 'success');
      document.getElementById('bp-note').value = '';
      document.getElementById('bp-pts').value  = '';
      await fetchData(true);
    } else {
      toast(r.message, 'error');
    }
  } catch(e) { toast('Lỗi kết nối', 'error'); }
  showLoad(false);
}

// ============================================================
// RENDER: REWARDS
// ============================================================
function renderRewards() {
  const el = document.getElementById('tab-rewards');
  const canRedeem = S.user?.role === 'admin' || S.user?.role === 'scorer' || S.user?.role === 'viewer';

  // For viewer: only show their child
  const redeemChildren = S.user?.role === 'viewer'
    ? S.children.filter(c => String(c.child_id) === String(S.user.child_id))
    : S.children;

  let childOpts = redeemChildren.map(c =>
    `<option value="${c.child_id}">${c.avatar_icon || ''} ${c.child_name} (${childScore(c.child_id).total_score} ⭐)</option>`
  ).join('');

  const rewardsHtml = S.rewards.length ? `
    <div class="form-row" style="margin-bottom:14px">
      <label>👶 Đổi thưởng cho</label>
      <select id="rd-child" class="form-select">${childOpts}</select>
    </div>
    <div class="rewards-grid">
      ${S.rewards.map(rw => {
        const maxScore = redeemChildren.length
          ? Math.max(...redeemChildren.map(c => childScore(c.child_id).total_score))
          : 0;
        const canAfford = maxScore >= Number(rw.required_points);
        return `
          <div class="reward-card">
            <span class="reward-icon">${rw.icon || '🎁'}</span>
            <div class="reward-name">${rw.reward_name}</div>
            <div class="reward-pts">${rw.required_points} ⭐</div>
            ${canRedeem ? `<button class="btn-redeem" onclick="submitRedeem('${rw.reward_id}')">🎁 Đổi thưởng</button>` : ''}
          </div>
        `;
      }).join('')}
    </div>
  ` : '<div class="empty-state"><div class="es-icon">🎁</div><p>Chưa có phần thưởng nào</p></div>';

  const redeemHist = S.redemptions.slice(0, 10).map(rd => `
    <div class="tx-item">
      <div class="tx-left">
        <div class="tx-name">${rd.child_name} · ${rd.reward_name}</div>
        <div class="tx-meta">${fmtDate(rd.date)} · ${rd.status || ''}</div>
      </div>
      <div class="tx-pts neg">-${rd.points_spent}</div>
    </div>
  `).join('') || '<div class="empty-state"><div class="es-icon">📜</div><p>Chưa có lịch sử đổi thưởng</p></div>';

  el.innerHTML = `
    <div class="sec-title">🎁 Phần Thưởng</div>
    ${rewardsHtml}
    <div class="redeem-history">
      <div class="sec-title" style="margin-top:20px">🔖 Lịch Sử Đổi Thưởng</div>
      ${redeemHist}
    </div>
  `;
}

async function submitRedeem(rewardId) {
  const childId = document.getElementById('rd-child')?.value;
  if (!childId) { toast('Chọn bé', 'warn'); return; }
  const child  = S.children.find(c => String(c.child_id) === String(childId));
  const reward = S.rewards.find(r => String(r.reward_id) === String(rewardId));
  if (!child || !reward) return;

  confirm(
    '🎁 Xác nhận đổi thưởng',
    `${child.child_name} đổi "${reward.reward_name}" tốn ${reward.required_points} ⭐`,
    async () => {
      showLoad(true);
      try {
        const r = await api('redeemReward', { child_id: childId, reward_id: rewardId });
        if (r.success) {
          toast(r.message, 'success');
          await fetchData(true);
        } else {
          toast(r.message, 'error');
        }
      } catch(e) { toast('Lỗi kết nối', 'error'); }
      showLoad(false);
    }
  );
}

