<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>🏆 Bảng Điểm Thưởng</title>
  <style>
    /* ============================================================
       RESET & BASE
    ============================================================ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      background: #0a0f1e;
      color: #e2e8f0;
      font-size: 15px;
    }

    /* ============================================================
       VARIABLES
    ============================================================ */
    :root {
      --red:    #c9184a;
      --red-l:  #ff4d79;
      --gold:   #f5c518;
      --blue:   #4cc9f0;
      --green:  #43aa8b;
      --purple: #7b2d8b;
      --bg0:    #0a0f1e;
      --bg1:    #131929;
      --bg2:    #1e2840;
      --bg3:    #243050;
      --border: rgba(255,255,255,0.08);
      --text:   #e2e8f0;
      --dim:    #8892a4;
      --radius: 14px;
    }

    /* ============================================================
       LOADING
    ============================================================ */
    #loading {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(10,15,30,0.88);
      display: none; align-items: center; justify-content: center;
      flex-direction: column; gap: 14px;
    }
    .spinner {
      width: 48px; height: 48px;
      border: 4px solid var(--bg3);
      border-top-color: var(--red);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ============================================================
       TOAST
    ============================================================ */
    #toast {
      position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
      background: var(--bg3); color: var(--text);
      padding: 10px 20px; border-radius: 30px;
      font-size: 14px; z-index: 8888;
      opacity: 0; transition: opacity 0.3s;
      max-width: 90vw; text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
      pointer-events: none;
    }
    #toast.show { opacity: 1; }
    #toast.success { background: var(--green); }
    #toast.error   { background: var(--red); }
    #toast.warn    { background: #d97706; }

    /* ============================================================
       MODAL CONFIRM
    ============================================================ */
    #modal-overlay {
      position: fixed; inset: 0; z-index: 7777;
      background: rgba(0,0,0,0.7);
      display: none; align-items: center; justify-content: center;
    }
    #modal-overlay.show { display: flex; }
    .modal-box {
      background: var(--bg2); border-radius: var(--radius);
      padding: 24px; max-width: 340px; width: 90%;
      border: 1px solid var(--border);
    }
    .modal-box h3 { margin-bottom: 10px; font-size: 17px; }
    .modal-box p  { color: var(--dim); font-size: 14px; margin-bottom: 20px; }
    .modal-btns   { display: flex; gap: 10px; }
    .modal-btns button {
      flex: 1; padding: 10px; border-radius: 8px;
      border: none; cursor: pointer; font-size: 14px; font-weight: 600;
    }
    .btn-confirm { background: var(--red); color: white; }
    .btn-cancel  { background: var(--bg3); color: var(--text); }

    /* ============================================================
       LOGIN SCREEN
    ============================================================ */
    #login-screen {
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
    }
    .login-card {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 36px 28px;
      width: 100%; max-width: 380px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .login-logo {
      text-align: center; margin-bottom: 28px;
    }
    .login-logo .logo-icon { font-size: 48px; display: block; margin-bottom: 8px; }
    .login-logo h1 { font-size: 20px; font-weight: 700; }
    .login-logo p  { font-size: 13px; color: var(--dim); margin-top: 4px; }

    .chars-row {
      display: flex; gap: 12px; margin-bottom: 24px;
    }
    .char-btn {
      flex: 1;
      background: var(--bg2);
      border: 2px solid var(--border);
      border-radius: 12px;
      padding: 12px 8px;
      cursor: pointer; text-align: center;
      transition: border-color 0.2s, background 0.2s;
      color: var(--text);
    }
    .char-btn:hover { border-color: var(--red); background: var(--bg3); }
    .char-btn.active { border-color: var(--gold); background: var(--bg3); }
    .char-btn .char-icon { font-size: 28px; display: block; margin-bottom: 4px; }
    .char-btn .char-name { font-size: 12px; font-weight: 600; }
    .char-btn .char-role { font-size: 11px; color: var(--dim); }

    .form-group { margin-bottom: 14px; }
    .form-group label { display: block; font-size: 12px; color: var(--dim); margin-bottom: 6px; }
    .input-wrap { position: relative; }
    .input-wrap input {
      width: 100%;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 11px 14px;
      color: var(--text); font-size: 15px;
      outline: none; transition: border-color 0.2s;
    }
    .input-wrap input:focus { border-color: var(--red); }
    .pw-toggle {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; color: var(--dim); cursor: pointer;
      font-size: 16px;
    }
    .login-error {
      background: rgba(201,24,74,0.15);
      border: 1px solid var(--red);
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 13px; color: var(--red);
      margin-bottom: 14px; display: none;
    }
    .btn-login {
      width: 100%;
      background: linear-gradient(135deg, var(--red), #a11040);
      color: white; border: none;
      border-radius: 12px; padding: 13px;
      font-size: 16px; font-weight: 700; cursor: pointer;
      transition: opacity 0.2s;
      margin-top: 4px;
    }
    .btn-login:hover { opacity: 0.9; }

    /* ============================================================
       APP LAYOUT
    ============================================================ */
    #app { display: none; height: 100vh; flex-direction: column; overflow: hidden; }
    #app.visible { display: flex; }

    .app-header {
      background: var(--bg1);
      border-bottom: 1px solid var(--border);
      padding: 12px 16px;
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0;
    }
    .app-header h1 { font-size: 16px; font-weight: 700; }
    .header-right { display: flex; align-items: center; gap: 10px; }
    .user-badge {
      font-size: 12px; color: var(--dim);
      background: var(--bg2); border-radius: 20px;
      padding: 4px 10px;
    }
    .btn-logout {
      background: var(--bg2); border: 1px solid var(--border);
      color: var(--dim); border-radius: 8px;
      padding: 5px 10px; font-size: 12px; cursor: pointer;
    }
    .btn-logout:hover { color: var(--red); border-color: var(--red); }
    .btn-refresh {
      background: none; border: none; color: var(--dim);
      font-size: 18px; cursor: pointer; padding: 4px;
      transition: transform 0.3s;
    }
    .btn-refresh.spinning { animation: spin 0.6s linear; }

    .tab-content-area {
      flex: 1; overflow-y: auto;
      padding: 16px 16px 80px;
    }

    /* ============================================================
       TAB NAV (bottom)
    ============================================================ */
    .tab-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      background: var(--bg1);
      border-top: 1px solid var(--border);
      display: flex; overflow-x: auto;
      scrollbar-width: none;
    }
    .tab-nav::-webkit-scrollbar { display: none; }
    .tab-btn {
      flex: 1; min-width: 60px;
      display: flex; flex-direction: column; align-items: center;
      padding: 8px 6px;
      background: none; border: none; color: var(--dim);
      cursor: pointer; font-size: 10px; gap: 3px;
      transition: color 0.2s;
      white-space: nowrap;
    }
    .tab-btn .tab-icon { font-size: 20px; }
    .tab-btn.active { color: var(--gold); }

    /* ============================================================
       SECTION TITLE
    ============================================================ */
    .sec-title {
      font-size: 17px; font-weight: 700;
      margin-bottom: 14px; padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    /* ============================================================
       TODAY TAB
    ============================================================ */
    .leaders-banner {
      background: linear-gradient(135deg, #1e1040, #2a1060);
      border: 1px solid rgba(124,58,237,0.3);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 16px;
      display: flex; gap: 12px;
    }
    .leader-item {
      flex: 1;
      background: rgba(0,0,0,0.25);
      border-radius: 10px; padding: 10px 12px;
    }
    .leader-label { font-size: 11px; color: var(--dim); display: block; margin-bottom: 4px; }
    .leader-name  { font-size: 14px; font-weight: 700; color: var(--gold); }

    .child-cards { display: flex; flex-direction: column; gap: 14px; }
    .child-card {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      overflow: hidden; position: relative;
    }
    .child-card-head {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 14px;
    }
    .child-card-avatar { font-size: 36px; }
    .child-card-info h3 { font-size: 17px; font-weight: 700; }
    .child-card-info span { font-size: 12px; color: var(--dim); }

    .score-row {
      display: grid; grid-template-columns: repeat(3,1fr);
      gap: 8px; margin-bottom: 14px;
    }
    .score-box {
      background: var(--bg2);
      border-radius: 10px; padding: 10px 6px;
      text-align: center;
    }
    .score-box .sv { font-size: 20px; font-weight: 700; color: var(--gold); }
    .score-box .sl { font-size: 11px; color: var(--dim); margin-top: 2px; }

    .prog-wrap { }
    .prog-label { display: flex; justify-content: space-between; font-size: 12px; color: var(--dim); margin-bottom: 5px; }
    .prog-bar { height: 8px; background: var(--bg3); border-radius: 4px; overflow: hidden; }
    .prog-fill { height: 100%; background: linear-gradient(90deg, var(--red), var(--gold)); border-radius: 4px; transition: width 0.5s; }

    /* ============================================================
       TASKS TAB
    ============================================================ */
    .cat-filter {
      display: flex; gap: 8px; overflow-x: auto;
      scrollbar-width: none; margin-bottom: 16px; padding-bottom: 2px;
    }
    .cat-filter::-webkit-scrollbar { display: none; }
    .cat-pill {
      flex-shrink: 0;
      padding: 6px 14px; border-radius: 20px;
      background: var(--bg2); border: 1px solid var(--border);
      color: var(--dim); font-size: 13px; cursor: pointer;
      white-space: nowrap; transition: all 0.2s;
    }
    .cat-pill.active {
      background: var(--red); border-color: var(--red);
      color: white;
    }

    .cat-section { margin-bottom: 20px; }
    .cat-section-title {
      font-size: 13px; font-weight: 600; color: var(--dim);
      margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px;
    }

    .task-item {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 14px;
      margin-bottom: 8px;
    }
    .task-item-head {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 10px;
    }
    .task-name-text { font-size: 14px; font-weight: 600; }
    .task-pts-badge {
      background: rgba(245,197,24,0.15);
      color: var(--gold);
      border-radius: 6px; padding: 2px 8px;
      font-size: 12px; font-weight: 700;
      white-space: nowrap;
    }
    .task-checks { display: flex; gap: 8px; flex-wrap: wrap; }
    .check-label {
      display: flex; align-items: center; gap: 6px;
      background: var(--bg2); border-radius: 8px;
      padding: 6px 12px; cursor: pointer;
      border: 1px solid var(--border);
      transition: border-color 0.2s, background 0.2s;
      user-select: none;
    }
    .check-label:hover { border-color: var(--red); }
    .check-label.done {
      background: rgba(67,170,139,0.15);
      border-color: var(--green);
    }
    .check-label input[type="checkbox"] { display: none; }
    .check-box {
      width: 18px; height: 18px;
      border: 2px solid var(--border);
      border-radius: 4px;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; flex-shrink: 0;
      transition: all 0.2s;
    }
    .check-label.done .check-box {
      background: var(--green);
      border-color: var(--green);
      color: white;
    }
    .check-child-name { font-size: 13px; }

    /* viewer — no interaction */
    .check-label.readonly { cursor: default; pointer-events: none; opacity: 0.8; }

    /* ============================================================
       POINTS TAB
    ============================================================ */
    .points-form {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
    }
    .form-row { margin-bottom: 14px; }
    .form-row label { display: block; font-size: 12px; color: var(--dim); margin-bottom: 6px; }
    .form-select, .form-input, .form-textarea {
      width: 100%;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
      color: var(--text); font-size: 14px; outline: none;
    }
    .form-select:focus, .form-input:focus { border-color: var(--red); }
    .type-toggle { display: flex; gap: 8px; }
    .type-btn {
      flex: 1; padding: 9px;
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 8px; color: var(--dim);
      cursor: pointer; font-size: 13px; font-weight: 600;
      transition: all 0.2s;
    }
    .type-btn.active-bonus  { background: rgba(67,170,139,0.2); border-color: var(--green);  color: var(--green); }
    .type-btn.active-penalty { background: rgba(201,24,74,0.2); border-color: var(--red); color: var(--red); }

    .btn-submit {
      width: 100%;
      background: linear-gradient(135deg, var(--red), #a11040);
      color: white; border: none; border-radius: 10px;
      padding: 12px; font-size: 15px; font-weight: 700;
      cursor: pointer; margin-top: 4px;
    }

    .recent-tx { margin-top: 20px; }
    .tx-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 10px 12px;
      background: var(--bg1); border-radius: 8px;
      border: 1px solid var(--border);
      margin-bottom: 6px; font-size: 13px;
    }
    .tx-left .tx-name { font-weight: 600; }
    .tx-left .tx-meta { font-size: 11px; color: var(--dim); margin-top: 2px; }
    .tx-pts { font-weight: 700; font-size: 15px; }
    .tx-pts.pos { color: var(--green); }
    .tx-pts.neg { color: var(--red); }

    /* ============================================================
       REWARDS TAB
    ============================================================ */
    .rewards-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; }
    .reward-card {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: 12px; padding: 14px;
      text-align: center;
    }
    .reward-icon { font-size: 32px; margin-bottom: 6px; display: block; }
    .reward-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
    .reward-pts  { font-size: 12px; color: var(--gold); margin-bottom: 10px; }
    .btn-redeem {
      width: 100%; padding: 7px;
      background: var(--bg3); border: 1px solid var(--border);
      color: var(--text); border-radius: 8px;
      font-size: 12px; cursor: pointer;
      transition: all 0.2s;
    }
    .btn-redeem:hover:not(:disabled) { background: var(--red); border-color: var(--red); }
    .btn-redeem:disabled { opacity: 0.4; cursor: not-allowed; }

    .redeem-history { margin-top: 20px; }

    /* ============================================================
       RANKINGS TAB
    ============================================================ */
    .rank-cards { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .rank-card {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: 12px; padding: 14px 16px;
      display: flex; align-items: center; gap: 14px;
    }
    .rank-num { font-size: 24px; font-weight: 900; min-width: 36px; text-align: center; }
    .rank-num.r1 { color: var(--gold); }
    .rank-num.r2 { color: #b0b0c0; }
    .rank-num.r3 { color: #cd7f32; }
    .rank-info { flex: 1; }
    .rank-info h3 { font-size: 15px; font-weight: 700; }
    .rank-info span { font-size: 12px; color: var(--dim); }
    .rank-score { font-size: 18px; font-weight: 700; color: var(--gold); }

    .compare-section {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: var(--radius); padding: 14px;
    }
    .compare-row {
      display: flex; align-items: center;
      margin-bottom: 8px; gap: 8px;
    }
    .compare-label { font-size: 12px; color: var(--dim); min-width: 80px; }
    .compare-bar-wrap { flex: 1; }
    .compare-bar-track { height: 10px; background: var(--bg3); border-radius: 5px; overflow: hidden; display: flex; }
    .cbar { height: 100%; border-radius: 5px; transition: width 0.5s; }
    .cbar.c1 { background: var(--red); }
    .cbar.c2 { background: var(--blue); }
    .compare-values { display: flex; gap: 8px; margin-top: 4px; font-size: 11px; color: var(--dim); }

    /* ============================================================
       HISTORY TAB
    ============================================================ */
    .chart-wrap {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: var(--radius); padding: 14px;
      margin-bottom: 16px;
      overflow-x: auto;
    }
    .chart-title { font-size: 13px; font-weight: 600; margin-bottom: 12px; }
    .bar-chart {
      display: flex; gap: 4px; align-items: flex-end;
      height: 120px; min-width: 280px;
    }
    .bar-group { flex: 1; display: flex; gap: 2px; align-items: flex-end; position: relative; }
    .bar { border-radius: 4px 4px 0 0; min-height: 4px; transition: height 0.5s; cursor: default; }
    .bar.b1 { background: var(--red); flex: 1; }
    .bar.b2 { background: var(--blue); flex: 1; }
    .bar-date { position: absolute; bottom: -18px; width: 100%; text-align: center; font-size: 9px; color: var(--dim); white-space: nowrap; }

    .chart-legend { display: flex; gap: 14px; margin-top: 24px; font-size: 12px; color: var(--dim); }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 4px; }

    /* ============================================================
       SETTINGS TAB
    ============================================================ */
    .settings-card {
      background: var(--bg1);
      border: 1px solid var(--border);
      border-radius: var(--radius); padding: 16px;
      margin-bottom: 14px;
    }
    .settings-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 14px; color: var(--gold); }
    .btn-setting {
      width: 100%; padding: 11px 14px;
      background: var(--bg2); border: 1px solid var(--border);
      color: var(--text); border-radius: 8px;
      font-size: 14px; cursor: pointer; text-align: left;
      margin-bottom: 8px; transition: border-color 0.2s;
    }
    .btn-setting:hover { border-color: var(--red); }
    .btn-setting.danger { border-color: rgba(201,24,74,0.3); color: var(--red); }
    .btn-setting.danger:hover { background: rgba(201,24,74,0.15); }

    .add-task-form, .add-reward-form {
      display: flex; flex-direction: column; gap: 10px;
    }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

    /* ============================================================
       EMPTY STATE
    ============================================================ */
    .empty-state { text-align: center; padding: 30px; color: var(--dim); }
    .empty-state .es-icon { font-size: 40px; margin-bottom: 8px; }
    .empty-state p { font-size: 14px; }

    /* ============================================================
       RESPONSIVE
    ============================================================ */
    @media (min-width: 600px) {
      .child-cards { flex-direction: row; flex-wrap: wrap; }
      .child-card  { flex: 1; min-width: 260px; }
      .rewards-grid { grid-template-columns: repeat(3,1fr); }
    }
  </style>
</head>
<body>

<!-- ============================================================
     LOADING
============================================================ -->
<div id="loading">
  <div class="spinner"></div>
  <span style="color:var(--dim);font-size:13px">Đang tải...</span>
</div>

<!-- ============================================================
     TOAST
============================================================ -->
<div id="toast"></div>

<!-- ============================================================
     MODAL CONFIRM
============================================================ -->
<div id="modal-overlay">
  <div class="modal-box">
    <h3 id="modal-title">Xác nhận</h3>
    <p  id="modal-body">Bạn chắc chắn muốn thực hiện thao tác này?</p>
    <div class="modal-btns">
      <button class="btn-cancel"  onclick="closeModal()">❌ Hủy</button>
      <button class="btn-confirm" id="modal-ok">✅ Xác nhận</button>
    </div>
  </div>
</div>

<!-- ============================================================
     LOGIN
============================================================ -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">
      <span class="logo-icon">🏆</span>
      <h1>Bảng Điểm Thưởng</h1>
      <p>Hành trình chinh phục mỗi ngày ✨</p>
    </div>

    <div class="chars-row" id="chars-row">
      <!-- filled by JS from DB -->
    </div>

    <form id="login-form" onsubmit="handleLogin(event)">
      <div class="login-error" id="login-error">❌ Tên đăng nhập hoặc mật khẩu không đúng!</div>
      <div class="form-group">
        <label>🧑‍🚀 Tên đăng nhập</label>
        <div class="input-wrap">
          <input id="inp-user" type="text" placeholder="username" autocomplete="username" />
        </div>
      </div>
      <div class="form-group">
        <label>🔐 Mật khẩu</label>
        <div class="input-wrap">
          <input id="inp-pass" type="password" placeholder="password" autocomplete="current-password" />
          <button type="button" class="pw-toggle" onclick="togglePw()">👁️</button>
        </div>
      </div>
      <button type="submit" class="btn-login">🚀 Đăng Nhập</button>
