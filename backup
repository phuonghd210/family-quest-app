// RENDER: RANKINGS
// ============================================================
function renderRankings() {
  const el = document.getElementById('tab-rankings');
  if (!S.children.length) {
    el.innerHTML = '<div class="empty-state"><div class="es-icon">🏅</div><p>Đang tải...</p></div>';
    return;
  }

  const scored = S.children
    .map(c => ({ ...c, ...childScore(c.child_id) }))
    .sort((a, b) => b.week_score - a.week_score);

  const rankEmojis = ['🥇','🥈','🥉'];

  const maxWeek = scored.length ? Math.max(...scored.map(c => c.week_score), 1) : 1;

  let rankCards = scored.map((c, i) => `
    <div class="rank-card">
      <div class="rank-num ${i < 3 ? 'r'+(i+1) : ''}">${rankEmojis[i] || (i+1)}</div>
      <div class="rank-info">
        <h3>${c.avatar_icon || ''} ${c.child_name}</h3>
        <span>Tổng: ${c.total_score} ⭐ · Hôm nay: ${c.today_score}</span>
      </div>
      <div class="rank-score">${c.week_score} ⭐</div>
    </div>
  `).join('');

  // Compare bars
  let compareBars = '';
  const allScored = S.children.map(c => ({ ...c, ...childScore(c.child_id) }));
  const maxWeekAll = Math.max(...allScored.map(c => c.week_score), 1);
  const colors = ['c1','c2','c3','c4'];

  ['today_score','week_score','total_score'].forEach(metric => {
    const labels = { today_score:'Hôm nay', week_score:'Tuần này', total_score:'Ngôi sao' };
    const maxVal = Math.max(...allScored.map(c => c[metric]), 1);
    compareBars += `
      <div class="compare-row">
        <span class="compare-label">${labels[metric]}</span>
        <div class="compare-bar-wrap">
          <div class="compare-bar-track">
            ${allScored.map((c,i) => `
              <div class="cbar ${colors[i]}" style="width:${Math.round(c[metric]/maxVal*100)}%"></div>
            `).join('')}
          </div>
          <div class="compare-values">
            ${allScored.map(c => `<span>${c.child_name}: ${c[metric]}</span>`).join('')}
          </div>
        </div>
      </div>
    `;
  });

  el.innerHTML = `
    <div class="sec-title">🏅 Xếp Hạng Tuần Này</div>
    <div class="rank-cards">${rankCards}</div>

    <div class="compare-section">
      <div class="sec-title" style="border:none;margin-bottom:12px">📊 So Sánh</div>
      ${compareBars}
    </div>
  `;
}

// ============================================================
// RENDER: HISTORY
// ============================================================
function renderHistory() {
  const el = document.getElementById('tab-history');
  if (!S.children.length || !S.today) {
    el.innerHTML = '<div class="empty-state"><div class="es-icon">📊</div><p>Đang tải...</p></div>';
    return;
  }

  // Build 7-day data from transactions
  const days = 7;
  const dayData = [];
  for (let i = days - 1; i >= 0; i--) {
    const d = new Date(S.today + 'T00:00:00');
    d.setDate(d.getDate() - i);
    const ds = d.toISOString().substring(0, 10);
    const entry = { date: ds, short: `${d.getDate()}/${d.getMonth()+1}`, scores: {} };
    S.children.forEach(c => {
      entry.scores[c.child_id] = S.transactions
        .filter(tx => String(tx.child_id) === String(c.child_id) && String(tx.date).substring(0,10) === ds)
        .reduce((sum, tx) => sum + Number(tx.points || 0), 0);
    });
    dayData.push(entry);
  }

  const allVals = dayData.flatMap(d => Object.values(d.scores));
  const maxVal  = Math.max(...allVals, 1);

  const colors = ['var(--red)', 'var(--blue)', 'var(--green)'];

  let barsHtml = dayData.map(d => {
    const childBars = S.children.map((c, i) => {
      const h = Math.max(4, Math.round((d.scores[c.child_id] / maxVal) * 100));
      return `<div class="bar b${i+1}" style="height:${h}px" title="${c.child_name}: ${d.scores[c.child_id]}"></div>`;
    }).join('');
    return `<div class="bar-group">${childBars}<span class="bar-date">${d.short}</span></div>`;
  }).join('');

  const legendHtml = S.children.map((c, i) => `
    <span>
      <span class="legend-dot" style="background:${colors[i] || '#fff'}"></span>
      ${c.child_name}
    </span>
  `).join('');

  // Recent transactions
  const recentTx = S.transactions.slice(0, 30);
  const txHtml = recentTx.length ? recentTx.map(tx => {
    const pts = Number(tx.points || 0);
    return `
      <div class="tx-item">
        <div class="tx-left">
          <div class="tx-name">${tx.child_name || ''} · ${tx.note || tx.task_name || tx.type || ''}</div>
          <div class="tx-meta">${fmtDatetime(tx.created_at)} · ${tx.created_by_name || ''}</div>
        </div>
        <div class="tx-pts ${pts >= 0 ? 'pos' : 'neg'}">${pts >= 0 ? '+' : ''}${pts}</div>
      </div>
    `;
  }).join('') : '<div class="empty-state"><div class="es-icon">📜</div><p>Chưa có dữ liệu</p></div>';

  el.innerHTML = `
    <div class="sec-title">📊 Lịch Sử</div>

    <div class="chart-wrap">
      <div class="chart-title">📈 Biểu Đồ 7 Ngày Gần Đây</div>
      <div class="bar-chart">${barsHtml}</div>
      <div class="chart-legend">${legendHtml}</div>
    </div>

    <div class="sec-title">📜 Giao Dịch Gần Đây</div>
    ${txHtml}
  `;
}

// ============================================================
// RENDER: SETTINGS
// ============================================================
function renderSettings() {
  const el   = document.getElementById('tab-settings');
  const role = S.user?.role;
  if (role !== 'admin' && role !== 'scorer') {
    el.innerHTML = '<div class="empty-state"><div class="es-icon">🔒</div><p>Chỉ dành cho admin/scorer</p></div>';
    return;
  }

  const cats = ['Tác phong hằng ngày','Việc nhà','Học tập','Điểm phát sinh','Thành tích'];
  const catOpts = cats.map(c => `<option value="${c}">${c}</option>`).join('');

  let assignOpts = `<option value="both">👥 Cả hai</option>` +
    S.children.map(c => `<option value="${c.child_key || c.child_id}">${c.avatar_icon || ''} ${c.child_name}</option>`).join('');

  let adminSection = '';
  if (role === 'admin') {
    adminSection = `
      <div class="settings-card">
        <h3>⚙️ Quản Lý Hệ Thống</h3>
        <button class="btn-setting" onclick="doResetToday()">🔄 Đặt Lại Nhiệm Vụ Hôm Nay</button>
        <button class="btn-setting danger" onclick="doResetWeek()">🗑️ Đặt Lại Điểm Tuần</button>
      </div>
    `;
  }

  el.innerHTML = `
    <div class="sec-title">⚙️ Cài Đặt</div>

    <div class="settings-card">
      <h3>➕ Thêm Nhiệm Vụ Mới</h3>
      <div class="add-task-form">
        <div class="form-row">
          <label>Tên nhiệm vụ</label>
          <input id="nt-name" class="form-input" type="text" placeholder="Tên nhiệm vụ..." />
        </div>
        <div class="form-row-2">
          <div>
            <label>Danh mục</label>
            <select id="nt-cat" class="form-select">${catOpts}</select>
          </div>
          <div>
            <label>Số điểm</label>
            <input id="nt-pts" class="form-input" type="number" min="1" placeholder="10" />
          </div>
        </div>
        <div class="form-row">
          <label>Giao cho</label>
          <select id="nt-assign" class="form-select">${assignOpts}</select>
        </div>
        <button class="btn-submit" onclick="submitAddTask()">✅ Thêm Nhiệm Vụ</button>
      </div>
    </div>

    <div class="settings-card">
      <h3>🎁 Thêm Phần Thưởng Mới</h3>
      <div class="add-reward-form">
        <div class="form-row">
          <label>Tên phần thưởng</label>
          <input id="nr-name" class="form-input" type="text" placeholder="Tên phần thưởng..." />
        </div>
        <div class="form-row-2">
          <div>
            <label>Icon</label>
            <input id="nr-icon" class="form-input" type="text" placeholder="🎁" />
          </div>
          <div>
            <label>Điểm cần</label>
            <input id="nr-pts" class="form-input" type="number" min="1" placeholder="200" />
          </div>
        </div>
        <button class="btn-submit" onclick="submitAddReward()">🎁 Thêm Phần Thưởng</button>
      </div>
    </div>

    ${adminSection}
  `;
}

async function submitAddTask() {
  const name   = document.getElementById('nt-name').value.trim();
  const cat    = document.getElementById('nt-cat').value;
  const pts    = Number(document.getElementById('nt-pts').value);
  const assign = document.getElementById('nt-assign').value;

  if (!name) { toast('Nhập tên nhiệm vụ', 'warn'); return; }
  if (!pts || pts <= 0) { toast('Nhập số điểm hợp lệ', 'warn'); return; }

  showLoad(true);
  try {
    const r = await api('addTask', { task_name: name, category: cat, points: pts, assigned_to: assign });
    if (r.success) {
      toast(r.message, 'success');
      document.getElementById('nt-name').value = '';
      document.getElementById('nt-pts').value  = '';
      await fetchData(true);
    } else { toast(r.message, 'error'); }
  } catch(e) { toast('Lỗi kết nối', 'error'); }
  showLoad(false);
}

async function submitAddReward() {
  const name = document.getElementById('nr-name').value.trim();
  const icon = document.getElementById('nr-icon').value.trim() || '🎁';
  const pts  = Number(document.getElementById('nr-pts').value);

  if (!name) { toast('Nhập tên phần thưởng', 'warn'); return; }
  if (!pts || pts <= 0) { toast('Nhập số điểm hợp lệ', 'warn'); return; }

  showLoad(true);
  try {
    const r = await api('addReward', { reward_name: name, icon, required_points: pts });
    if (r.success) {
      toast(r.message, 'success');
      document.getElementById('nr-name').value = '';
      document.getElementById('nr-icon').value = '';
      document.getElementById('nr-pts').value  = '';
      await fetchData(true);
    } else { toast(r.message, 'error'); }
  } catch(e) { toast('Lỗi kết nối', 'error'); }
  showLoad(false);
}

async function doResetToday() {
  confirm('🔄 Đặt lại nhiệm vụ?', 'Xóa toàn bộ tick hôm nay (điểm không đổi). Chắc chắn?', async () => {
    showLoad(true);
    try {
      const r = await api('resetToday');
      if (r.success) { toast(r.message, 'success'); await fetchData(true); }
      else            toast(r.message, 'error');
    } catch(e) { toast('Lỗi kết nối', 'error'); }
    showLoad(false);
  });
}

async function doResetWeek() {
  confirm('🗑️ Đặt lại điểm tuần?', '⚠️ Sẽ xóa toàn bộ giao dịch tuần này. Không thể hoàn tác!', async () => {
    showLoad(true);
    try {
      const r = await api('resetWeek');
      if (r.success) { toast(r.message, 'success'); await fetchData(true); }
      else            toast(r.message, 'error');
    } catch(e) { toast('Lỗi kết nối', 'error'); }
    showLoad(false);
  });
}

